                {
                  "key": "field_nav_has_mega_menu_fc",
                  "label": "Has Mega Menu",
                  "name": "has_mega_menu",
                  "type": "true_false",
                  "default_value": 0
                },
                {
                  "key": "field_nav_mega_menu_columns_fc",
                  "label": "Mega Menu Columns",
                  "name": "mega_menu_columns",
                  "type": "repeater",
                  "conditional_logic": [
                    [
                      {
                        "field": "field_nav_has_mega_menu_fc",
                        "operator": "==",
                        "value": "1"
                      }
                    ]
                  ],
                  "sub_fields": [
                    {
                      "key": "field_mega_column_title_fc",
                      "label": "Column Title",
                      "name": "title",
                      "type": "text"
