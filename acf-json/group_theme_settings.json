    {
      "key": "field_font_source",
      "label": "Font Source",
      "name": "font_source",
      "type": "select",
      "instructions": "Choose between Google Fonts or self-hosted fonts",
      "choices": {
        "google": "Google Fonts",
        "self_hosted": "Self-Hosted Fonts"
      },
      "default_value": "google"
    },
    {
      "key": "field_google_font_primary",
      "label": "Primary Font (Google)",
      "name": "google_font_primary",
      "type": "text",
      "instructions": "Google Font name (e.g., 'Inter', 'Roboto', 'Open Sans')",
      "default_value": "Inter",
      "conditional_logic": [
        [
          {
            "field": "field_font_source",
            "operator": "==",
            "value": "google"
          }
        ]
      ],
      "wrapper": {
        "width": "50"
      }
    },
    {
      "key": "field_google_font_secondary",
      "label": "Secondary Font (Google)",
      "name": "google_font_secondary",
      "type": "text",
      "instructions": "Optional secondary font for headings",
      "placeholder": "Leave empty to use primary font",
      "conditional_logic": [
        [
          {
            "field": "field_font_source",
            "operator": "==",
            "value": "google"
          }
        ]
      ],
      "wrapper": {
        "width": "50"
      }
    },
    {
      "key": "field_google_font_weights",
      "label": "Font Weights",
      "name": "google_font_weights",
      "type": "checkbox",
      "instructions": "Select font weights to load",
      "choices": {
        "300": "Light (300)",
        "400": "Regular (400)",
        "500": "Medium (500)",
        "600": "Semi-Bold (600)",
        "700": "Bold (700)",
        "800": "Extra-Bold (800)"
      },
      "default_value": ["400", "600", "700"],
      "conditional_logic": [
        [
          {
            "field": "field_font_source",
            "operator": "==",
            "value": "google"
          }
        ]
      ]
    },
    {
      "key": "field_self_hosted_fonts",
      "label": "Self-Hosted Font Files",
      "name": "self_hosted_fonts",
      "type": "repeater",
      "instructions": "Upload font files (WOFF2 recommended for best performance)",
      "button_label": "Add Font",
      "conditional_logic": [
        [
          {
            "field": "field_font_source",
            "operator": "==",
            "value": "self_hosted"
          }
        ]
      ],
      "sub_fields": [
        {
          "key": "field_font_family_name",
          "label": "Font Family Name",
          "name": "family_name",
          "type": "text",
          "instructions": "CSS font-family name (e.g., 'MyCustomFont')",
          "wrapper": {
            "width": "33"
          }
        },
        {
          "key": "field_font_weight",
          "label": "Weight",
          "name": "weight",
          "type": "select",
          "choices": {
            "300": "Light (300)",
            "400": "Regular (400)",
            "500": "Medium (500)",
            "600": "Semi-Bold (600)",
            "700": "Bold (700)",
            "800": "Extra-Bold (800)"
          },
          "default_value": "400",
          "wrapper": {
            "width": "33"
          }
        },
        {
          "key": "field_font_style",
          "label": "Style",
          "name": "style",
          "type": "select",
          "choices": {
            "normal": "Normal",
            "italic": "Italic"
          },
          "default_value": "normal",
          "wrapper": {
            "width": "34"
          }
        },
        {
          "key": "field_font_file_woff2",
          "label": "WOFF2 File",
          "name": "file_woff2",
          "type": "file",
          "return_format": "array",
          "mime_types": "woff2",
          "wrapper": {
            "width": "50"
          }
        },
        {
          "key": "field_font_file_woff",
          "label": "WOFF File (Fallback)",
          "name": "file_woff",
          "type": "file",
          "return_format": "array",
          "mime_types": "woff",
          "wrapper": {
            "width": "50"
