{
  "key": "group_video",
  "title": "Video",
  "fields": [
    {
      "key": "field_video_type",
      "label": "Video Type",
      "name": "video_type",
      "type": "select",
      "choices": {
        "upload": "Upload Video",
        "youtube": "YouTube",
        "vimeo": "Vimeo"
      },
      "default_value": "youtube",
      "required": 1
    },
    {
      "key": "field_video_file",
      "label": "Video File",
      "name": "video_file",
      "type": "file",
      "return_format": "array",
      "library": "all",
      "mime_types": "mp4,webm,ogg",
      "conditional_logic": [
        [
          {
            "field": "field_video_type",
            "operator": "==",
            "value": "upload"
          }
        ]
      ],
      "required": 1
    },
    {
      "key": "field_video_youtube_id",
      "label": "YouTube Video ID",
      "name": "video_youtube_id",
      "type": "text",
      "instructions": "Enter YouTube video ID (e.g., dQw4w9WgXcQ)",
      "placeholder": "dQw4w9WgXcQ",
      "conditional_logic": [
        [
          {
            "field": "field_video_type",
            "operator": "==",
            "value": "youtube"
          }
        ]
      ],
      "required": 1
    },
    {
      "key": "field_video_vimeo_id",
      "label": "Vimeo Video ID",
      "name": "video_vimeo_id",
      "type": "text",
      "instructions": "Enter Vimeo video ID (e.g., 123456789)",
      "placeholder": "123456789",
      "conditional_logic": [
        [
          {
            "field": "field_video_type",
            "operator": "==",
            "value": "vimeo"
          }
        ]
      ],
      "required": 1
    },
    {
      "key": "field_video_poster",
      "label": "Poster Image",
      "name": "video_poster",
      "type": "image",
      "return_format": "array",
      "instructions": "Thumbnail shown before video plays (for uploaded videos)"
    },
    {
      "key": "field_video_caption",
      "label": "Caption",
      "name": "video_caption",
      "type": "text",
      "instructions": "Optional caption below video"
    },
    {
      "key": "field_video_aspect_ratio",
      "label": "Aspect Ratio",
      "name": "video_aspect_ratio",
      "type": "select",
      "choices": {
        "16-9": "16:9 (Widescreen)",
        "4-3": "4:3 (Standard)",
        "1-1": "1:1 (Square)",
        "21-9": "21:9 (Ultrawide)"
      },
      "default_value": "16-9"
    }
  ],
  "location": [
    [
      {
        "param": "post_type",
        "operator": "==",
        "value": "page"
      }
    ]
  ],
  "acfe_display_title": "",
  "acfe_autosync": ["json"],
  "acfe_form": 0
}
